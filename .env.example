DEBUG=True

# Shared database used by auth-api and area-api.
# PostGIS must be enabled because users.authorized_area is a geometry column.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/auth_db

# Optional fallback for area-api if DATABASE_URL is not set.
# For the current split, keep both APIs on DATABASE_URL to preserve behavior.
AREA_DATABASE_URL=

ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
