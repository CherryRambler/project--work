# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string with the asyncpg driver.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/auth_db

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Must be two DIFFERENT high-entropy secrets (min 32 random bytes, hex-encoded).
# Generate each with:  python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_secret

# ── Token Lifetimes ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── JWT Algorithm ─────────────────────────────────────────────────────────────
ALGORITHM=HS256
